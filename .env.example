# OpenRouter API Key (required for LLM calls)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override the default model (defaults to google/gemini-2.5-flash)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: Gemini API Key (if using Gemini directly)
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional: ConvertAPI credentials (for PDF to image conversion)
# CONVERTAPI_SECRET=your_convertapi_secret_here
